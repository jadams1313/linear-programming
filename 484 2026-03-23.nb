  RowBox[{"b2", "=", 
   RowBox[{"-", "12"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"b3", "=", "6"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", "x1_", "]"}], "=", 
   RowBox[{"x2", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"g1", "[", 
         RowBox[{"x1", ",", "x2"}], "]"}], "\[Equal]", "b1"}], ",", 
       RowBox[{"{", "x2", "}"}]}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", "x1_", "]"}], "=", 
   RowBox[{"x2", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"g2", "[", 
         RowBox[{"x1", ",", "x2"}], "]"}], "\[Equal]", "b2"}], ",", 
       RowBox[{"{", "x2", "}"}]}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{

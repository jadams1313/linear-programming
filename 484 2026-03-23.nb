Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"g1", "[", 
     RowBox[{"x1_", ",", "x2_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"1", "x1"}], " ", "-", 
     RowBox[{"3", "x2"}]}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"g2", "[", 

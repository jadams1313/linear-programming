    RowBox[{
     RowBox[{
      RowBox[{"-", "6"}], "x"}], " ", "-", " ", 
     RowBox[{"4", "y"}], " ", "+", " ", "5"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b1", "=", "6"}], ";"}], "\[IndentingNewLine]", 

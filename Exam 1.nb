Cell[BoxData[
 RowBox[{
  RowBox[{"pivot", "[", 
   RowBox[{"iStar_", ",", "jStar_", ",", "tab_"}], "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"newTab", "=", "tab"}], ";", "\[IndentingNewLine]", 
    RowBox[{"rows", "=", 
     RowBox[{
      RowBox[{"Dimensions", "[", "tab", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"cols", "=", 
     RowBox[{
      RowBox[{"Dimensions", "[", "tab", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"switch", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"newTab", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "jStar"}], "]"}], "]"}], "=", 
     RowBox[{"tab", "[", 
      RowBox[{"[", 
       RowBox[{"iStar", ",", "cols"}], "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"newTab", "[", 
      RowBox[{"[", 
       RowBox[{"iStar", ",", "cols"}], "]"}], "]"}], "=", 
     RowBox[{"tab", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "jStar"}], "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"ii", "=", "2"}], ",", 
      RowBox[{"ii", "<=", "rows"}], ",", 
      RowBox[{"ii", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"jj", "=", "1"}], ",", 
        RowBox[{"jj", "<", "cols"}], ",", 
        RowBox[{"jj", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "==", "iStar"}], "&&", 
             RowBox[{"jj", "==", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"newTab", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{"1", "/", 
              RowBox[{"tab", "[", 
               RowBox[{"[", 
                RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}], "]"}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "==", "iStar"}], "&&", 
             RowBox[{"jj", "!=", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"newTab", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"tab", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", "jj"}], "]"}], "]"}]}], "/", 
              RowBox[{"tab", "[", 
               RowBox[{"[", 
                RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}], "]"}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "!=", "iStar"}], "&&", 
             RowBox[{"jj", "==", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"newTab", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"tab", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "/", 
              RowBox[{"tab", "[", 
               RowBox[{"[", 
                RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}], "]"}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "!=", "iStar"}], "&&", 
             RowBox[{"jj", "!=", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"newTab", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"tab", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "-", 
              RowBox[{
               RowBox[{"tab", "[", 
                RowBox[{"[", 
                 RowBox[{"iStar", ",", "jj"}], "]"}], "]"}], 
               RowBox[{
                RowBox[{"tab", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", "jStar"}], "]"}], "]"}], "/", 
                RowBox[{"tab", "[", 
                 RowBox[{"[", 
                  RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}]}]}], 
           "]"}], ";"}], "\[IndentingNewLine]", "}"}]}], 
       "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Return", "[", "newTab", "]"}]}], "\[IndentingNewLine]", 
   ")"}]}]], "Input",

Cell[BoxData[
 RowBox[{
  RowBox[{"pivot", "[", 
   RowBox[{"iStar_", ",", "jStar_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mm", "=", "m"}], ";", "\[IndentingNewLine]", 
    RowBox[{"numRows", "=", 
     RowBox[{
      RowBox[{"Dimensions", "[", "m", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"numCols", "=", 
     RowBox[{
      RowBox[{"Dimensions", "[", "m", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"switch", " ", "row", " ", "vars"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mm", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "jStar"}], "]"}], "]"}], "=", 
     RowBox[{"m", "[", 
      RowBox[{"[", 
       RowBox[{"iStar", ",", "numCols"}], "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mm", "[", 
      RowBox[{"[", 
       RowBox[{"iStar", ",", "numCols"}], "]"}], "]"}], "=", 
     RowBox[{"m", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "jStar"}], "]"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"switch", " ", "col", " ", "vars"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mm", "[", 
      RowBox[{"[", 
       RowBox[{"numRows", ",", "jStar"}], "]"}], "]"}], "=", 
     RowBox[{"-", 
      RowBox[{"m", "[", 
       RowBox[{"[", 
        RowBox[{"iStar", ",", "1"}], "]"}], "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"mm", "[", 
      RowBox[{"[", 
       RowBox[{"iStar", ",", "1"}], "]"}], "]"}], "=", 
     RowBox[{"-", 
      RowBox[{"m", "[", 
       RowBox[{"[", 
        RowBox[{"numRows", ",", "jStar"}], "]"}], "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Changed", " ", "counter", " ", "vars", " ", "i", " ", "and", " ", "j", " ",
       "to", " ", "ii", " ", "and", " ", "jj", " ", "to", " ", "allow", " ", 
      "i", " ", "and", " ", "j", " ", "to", " ", "be", " ", "used", " ", "as",
       " ", "tableau", " ", "names"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"ii", "=", "2"}], ",", 
      RowBox[{"ii", "<", "numRows"}], ",", 
      RowBox[{"ii", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"jj", "=", "2"}], ",", 
        RowBox[{"jj", "<", "numCols"}], ",", 
        RowBox[{"jj", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "\[Equal]", "iStar"}], "&&", 
             RowBox[{"jj", "\[Equal]", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"mm", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{"1", "/", 
              RowBox[{"m", "[", 
               RowBox[{"[", 
                RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}], "]"}], ",", 
          RowBox[{"(*", " ", 
           RowBox[{"p", " ", "\[Rule]", " ", 
            RowBox[{"1", "/", "p"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "\[Equal]", "iStar"}], "&&", 
             RowBox[{"jj", "\[NotEqual]", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"mm", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"m", "[", 
                RowBox[{"[", 
                 RowBox[{"ii", ",", "jj"}], "]"}], "]"}]}], "/", 
              RowBox[{"m", "[", 
               RowBox[{"[", 
                RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}], "]"}], ",", 
          RowBox[{"(*", " ", 
           RowBox[{"q", " ", "\[Rule]", " ", 
            RowBox[{
             RowBox[{"-", "q"}], "/", "p"}]}], " ", "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "\[NotEqual]", "iStar"}], "&&", 
             RowBox[{"jj", "\[Equal]", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"mm", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"m", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "/", 
              RowBox[{"m", "[", 
               RowBox[{"[", 
                RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}], "]"}], ",", 
          RowBox[{"(*", " ", 
           RowBox[{"r", " ", "\[Rule]", " ", 
            RowBox[{"r", "/", "p"}]}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"ii", "\[NotEqual]", "iStar"}], "&&", 
             RowBox[{"jj", "\[NotEqual]", "jStar"}]}], ",", 
            RowBox[{
             RowBox[{"mm", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"m", "[", 
               RowBox[{"[", 
                RowBox[{"ii", ",", "jj"}], "]"}], "]"}], "-", 
              RowBox[{
               RowBox[{"m", "[", 
                RowBox[{"[", 
                 RowBox[{"iStar", ",", "jj"}], "]"}], "]"}], "*", 
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", "jStar"}], "]"}], "]"}], "/", 
                RowBox[{"m", "[", 
                 RowBox[{"[", 
                  RowBox[{"iStar", ",", "jStar"}], "]"}], "]"}]}]}]}]}]}], 
           "]"}]}], 
         RowBox[{"(*", " ", 
          RowBox[{"s", " ", "\[Rule]", " ", 
           RowBox[{"s", "-", 
            RowBox[{"qr", "/", "p"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
         "}"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
     "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Return", "[", "mm", "]"}]}], "\[IndentingNewLine]", 
   ")"}]}]], "Input",
